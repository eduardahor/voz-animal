rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function meuId() {
      return request.auth.uid;
    }

    function isOrgao() {
      return autenticado()
          && get(/databases/$(database)/documents/usuarios/$(meuId())).data.tipo == 'orgao';
    }

    function isCidadao() {
      return autenticado()
          && get(/databases/$(database)/documents/usuarios/$(meuId())).data.tipo == 'cidadao';
    }

    function denunciaAtual(denunciaId) {
      return get(/databases/$(database)/documents/denuncias/$(denunciaId)).data;
    }

    function souResponsavel(denunciaId) {
      return denunciaAtual(denunciaId).orgaoResponsavelId == meuId();
    }

    function souDono(denunciaId) {
      return denunciaAtual(denunciaId).usuarioId == meuId();
    }

    function somenteAlterou(campos) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(campos);
    }

    function naoAlterou(campos) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(campos);
    }

    function transicaoValida(de, para) {
      return (de == 'em_analise'  && (para == 'em_andamento' || para == 'recusada'))
          || (de == 'em_andamento' && (para == 'resolvida'    || para == 'recusada'));
    }

    match /usuarios/{uid} {
      allow read: if autenticado() && meuId() == uid;
      allow create: if autenticado() && meuId() == uid;
      allow update: if autenticado() && meuId() == uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tipo', 'id']);
      allow delete: if false;
    }

    match /denuncias/{denunciaId} {

      allow read: if autenticado();

      allow create: if isCidadao()
          && request.resource.data.usuarioId == meuId()
          && request.resource.data.status == 'aberta'
          && request.resource.data.orgaoResponsavelId == null
          && request.resource.data.descricao is string
          && request.resource.data.descricao.size() >= 20
          && (!('denuncianteCpf' in request.resource.data)
              || request.resource.data.denuncianteCpf is string);

      allow update: if isOrgao()
          && _updatePermitido(denunciaId)
          && naoAlterou([
               'denuncianteNome', 'denuncianteTelefone',
               'denuncianteEmail', 'denuncianteCpf',
               'usuarioId', 'descricao', 'tipo', 'criadoEm'
             ]);

      allow delete: if false;

      match /historico/{itemId} {
        allow read:   if autenticado();
        allow create: if isOrgao();
        allow update, delete: if false;
      }
    }

    function _updatePermitido(denunciaId) {
      let atual = resource.data;
      let novo  = request.resource.data;
      let status  = atual.status;
      let novoStatus = novo.status;

      let isAssumir = status == 'aberta'
          && novoStatus == 'em_analise'
          && novo.orgaoResponsavelId == meuId()
          && (
               !atual.bloqueadosAte.keys().hasAll([meuId()])
               || atual.bloqueadosAte[meuId()] < request.time
             );

      let isAlterarStatus = souResponsavel(denunciaId)
          && transicaoValida(status, novoStatus)
          && novo.orgaoResponsavelId == atual.orgaoResponsavelId
          && somenteAlterou(['status', 'atualizadoEm']);

      let isDevolver = souResponsavel(denunciaId)
          && novoStatus == 'aberta'
          && novo.orgaoResponsavelId == null
          && (status == 'em_analise' || status == 'em_andamento');

      return isAssumir || isAlterarStatus || isDevolver;
    }
  }

  match /cpfs_em_uso/{cpf} {
    allow get: if true;
    allow list: if false;
    allow create, update, delete: if autenticado();
  }

  match /cnpjs_em_uso/{cnpj} {
    allow get: if true;
    allow list: if false;
    allow create, update, delete: if autenticado();
  }
}
